# Copy these to the MCP server env block in ~/.claude.json. Never commit real keys.
# Tools whose key is missing error when called; you can start with one provider.

# ElevenLabs — voice synthesis and cloning
# Get a key at https://elevenlabs.io
ELEVENLABS_API_KEY=

# fal.ai — lipsync, face restoration (veed/fabric-1.0, musetalk, latentsync, sync-lipsync, codeformer)
# Get a key at https://fal.ai
FAL_KEY=

# HeyGen — polished talking-head renders (v3 API, uses plan credits)
# Get a key at https://app.heygen.com/settings/api
HEYGEN_API_KEY=

# ffmpeg must be on the system PATH for master_audio and assemble_video.
# Windows: winget install Gyan.FFmpeg
# macOS:   brew install ffmpeg
# Linux:   apt install ffmpeg
